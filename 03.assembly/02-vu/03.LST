     1                                  ; from 16 bit calculation to 8 bit 
     2                                  
     3                                  [org 0x0100]
     4                                  
     5 00000000 A0[1700]                    mov al, [num1]
     6 00000003 8A1E[1800]                  mov bl, [num1 + 1]
     7 00000007 00D8                        add al, bl
     8 00000009 8A1E[1900]                  mov bl, [num1 + 2]
     9 0000000D 00D8                        add al, bl
    10 0000000F A2[1A00]                    mov [result], al
    11 00000012 B8004C                      mov ax, 0x4c00 ; this line is for exit (0x4c00 is 16-bit so this can't move into al or ah only ax!)
    12 00000015 CD21                        int 0x21
    13                                  
    14 00000017 050A0F                  num1: db  5, 10, 15
    15 0000001A 00                      result: db 0
